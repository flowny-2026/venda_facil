{
  "buildCommand": "cd admin-system && npm install && npm run build",
  "outputDirectory": "admin-system/dist",
  "routes": [
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "^/admin(/.*)?",
      "dest": "/admin-system/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/admin-system/dist/$1"
    }
  ]
}
