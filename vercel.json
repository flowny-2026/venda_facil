{
  "version": 2,
  "builds": [
    {
      "src": "admin-system/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "cliente-system/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "^/admin$",
      "dest": "/admin-system/dist/index.html"
    },
    {
      "src": "^/admin/(.*)",
      "dest": "/admin-system/dist/$1"
    },
    {
      "src": "^/cliente$",
      "dest": "/cliente-system/dist/index.html"
    },
    {
      "src": "^/cliente/(.*)",
      "dest": "/cliente-system/dist/$1"
    },
    {
      "src": "^/(.*)",
      "dest": "/public/$1"
    }
  ]
}
