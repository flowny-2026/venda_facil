{
  "version": 2,
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "/admin-system/dist/index.html"
    },
    {
      "source": "/cliente/:path*",
      "destination": "/cliente-system/dist/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "public"
}